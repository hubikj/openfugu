# Copy this file to "keystore.properties" (which is gitignored) and fill in your own
# values to enable signed release builds. NEVER commit keystore.properties or the .jks file.
#
# storeFile  — absolute path to your release keystore (.jks), kept OUTSIDE the repo
# storePassword / keyPassword — the passwords you chose when running keytool
# keyAlias   — the alias you chose when running keytool

storeFile=/home/youruser/keys/openfugu-release.jks
storePassword=CHANGE_ME
keyAlias=openfugu
keyPassword=CHANGE_ME
