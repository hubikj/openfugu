<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Fish sized to fill most of the 66dp safe zone (radius 33 around 54,54).
         Positioned by visual weight, not bounding box: the body circle carries
         most of the mass, so the shape is nudged up-left until the area
         centroid sits near 54,54 while the tail stays inside the safe zone. -->

    <!-- Tail fin (triangle, drawn first so body overlaps base) -->
    <path
        android:fillColor="#FF8C00"
        android:pathData="M40.3,55.4 L24.7,45.0 L24.7,65.8 Z" />

    <!-- Dorsal fin (drawn before body so body overlaps base) -->
    <path
        android:fillColor="#FF8C00"
        android:pathData="M53.3,37.2 L59.8,26.8 L66.3,37.2 Z" />

    <!-- Body (orange circle, radius ~21) -->
    <path
        android:fillColor="#FFB347"
        android:pathData="M58.5,55.4m-20.8,0a20.8,20.8 0,1 1,41.6 0a20.8,20.8 0,1 1,-41.6 0" />

    <!-- Eye white -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M66.3,51.5m-5.9,0a5.9,5.9 0,1 1,11.8 0a5.9,5.9 0,1 1,-11.8 0" />

    <!-- Eye pupil -->
    <path
        android:fillColor="#000000"
        android:pathData="M67.6,51.5m-2.9,0a2.9,2.9 0,1 1,5.8 0a2.9,2.9 0,1 1,-5.8 0" />

    <!-- Mouth -->
    <path
        android:fillColor="#00000000"
        android:pathData="M75.4,58.0 L71.5,59.3"
        android:strokeWidth="2"
        android:strokeColor="#000000" />
</vector>
