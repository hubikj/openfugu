<?xml version="1.0" encoding="utf-8"?>
<!-- Applies below API 31. Session trace files are large (up to 50 x multi-MB)
     and can exceed the Auto Backup quota, silently failing the whole backup —
     including the SharedPreferences that hold profiles and calibration.
     Listing an include switches backup to opt-in mode: only prefs are backed
     up, so the bulky session traces in the file domain are excluded. -->
<full-backup-content>
    <include domain="sharedpref" path="."/>
</full-backup-content>
